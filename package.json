{
  "name": "claunch",
  "version": "0.1.0",
  "description": "Native Windows CLI tool that manages multiple Claude Code sessions across Git worktrees",
  "type": "module",
  "bin": {
    "claunch": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "claude",
    "worktree",
    "windows-terminal",
    "cli",
    "session-manager"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.1.0"
  }
}
